# Local-only secrets reference (keystore creds, API keys, build notes).
LOCAL-SECRETS.md
# google-services.json + GoogleService-Info.plist are NOT secrets — they
# only carry public client identifiers + API keys. Firestore Rules + the
# SHA-1 fingerprint registered in Firebase Console are the real security
# boundary. Committing them lets EAS Build pick them up via git.
GoogleService-Info.plist
ios/
android/

# Claude Code session data + Firebase CLI cache (machine-local)
.claude/
.firebase/

# Build artefacts — never commit binaries.
*.aab
*.apk
public/downloads/

# Generated at functions build time by scripts/copy-template.js. Kept
# out of source control so the function-side copy never drifts from
# public/c/index.html — the predeploy script regenerates it.
functions/templates/
