{
  "name": "footy-functions",
  "private": true,
  "description": "Cloud Functions for the Footy app — push notification consumer.",
  "main": "lib/index.js",
  "engines": {
    "node": "20"
  },
  "scripts": {
    "build": "node scripts/copy-template.js && tsc",
    "build:watch": "tsc --watch",
