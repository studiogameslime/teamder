# Copy to .env and fill in real values from your Firebase project + Google Cloud.
# All values prefixed EXPO_PUBLIC_ are bundled into the app at build time —
# they are NOT secret. Anything sensitive must live in Cloud Functions /
# server-side rules instead.

# ── Firebase web SDK config (from Firebase Console → Project Settings) ────
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=
EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Google OAuth client IDs (from Google Cloud → APIs & Services → Credentials) ──
# Web client ID is the one Firebase Auth uses to validate id_tokens. It MUST
# come from the same Google Cloud project as Firebase. Generate the
# iOS / Android client IDs separately.
EXPO_PUBLIC_GOOGLE_OAUTH_WEB_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_OAUTH_IOS_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_OAUTH_ANDROID_CLIENT_ID=

# Optional: force mock mode even if Firebase config is filled in.
# Useful for offline dev. Default: auto-detect from above values.
# EXPO_PUBLIC_FOOTY_FORCE_MOCK=1

# ── Israeli location autocomplete (data.gov.il) ──────────────────────────
# The cities resource_id is hardcoded in src/services/israelLocationService.ts
# (b7cf8f14-64a2-4b33-8d4b-edb286fdbd37). The streets resource_id varies and
# may change; set it here once identified. Empty value disables street
# autocomplete and the form falls back to free-text typing.
EXPO_PUBLIC_ISRAEL_STREETS_RESOURCE_ID=

# ── AdMob (OPT-IN — off by default) ──────────────────────────────────────
# Master switch. Set to "1" to enable the entire ads pipeline. When off
# (default), the ad service never tries to load the native module and
# BannerAd / showAppOpenAdIfAvailable() are pure no-ops. Leave this empty
# unless you have BOTH the npm package installed AND a custom dev client.
EXPO_PUBLIC_ADMOB_ENABLED=

# AdMob App ID. The Android meta-data value is set via the literal in
# app.json `react-native-google-mobile-ads` plugin entry (config plugins
# can't read env at parse time). This var is mostly informational.
EXPO_PUBLIC_ADMOB_APP_ID=

# Ad unit IDs (production). In __DEV__ the app falls back to Google's
# test units automatically. Real values here are only used in release
# builds.
#   Test units, for reference:
#     Banner:   ca-app-pub-3940256099942544/6300978111
#     App-open: ca-app-pub-3940256099942544/9257395921
EXPO_PUBLIC_ADMOB_BANNER_UNIT_ID=
EXPO_PUBLIC_ADMOB_APP_OPEN_UNIT_ID=

# Internal-testing override: serve AdMob TEST ads in release builds.
# Useful while the production AdMob unit is still warming up (fresh
# units take time to start serving). Set to 0 before publishing.
EXPO_PUBLIC_ADMOB_USE_TEST_IDS=

# ── App Check (debug only) ───────────────────────────────────────────────
# In production builds Play Integrity issues real tokens automatically.
# In dev builds, set the per-device debug token Firebase prints to logcat
# after the first run, then register it in:
#   Firebase Console → App Check → Apps → Manage debug tokens.
# Leaving this empty in dev still works — the SDK mints a fresh debug
# token at runtime and logs it.
EXPO_PUBLIC_APP_CHECK_DEBUG_TOKEN=
