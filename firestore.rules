rules_version = '2';

// v2 rules. Updated to match the renamed collections / fields:
//   /gameNights → /games   ·   gameNightId → gameId   ·   isOpenForRequests dropped
//   registeredUserIds → players   ·   waitlistUserIds → waitlist
//   pendingUserIds → pending   ·   participantIds (denormalized union)
//
// Posture: middle-ground. Reads are open to any signed-in user; writes are
// constrained to "self" patterns where it's cheap to express (own user
// doc, self-add to community-pending, self-add to game-participant).
// Anything else is gated behind being a group admin or the game's
// organizer (createdBy). Production hardening (stricter array diffs,
// per-field writes) can come on top of this.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ─────────────────────────────────────────────────────────

    function isSignedIn() {
      return request.auth != null;
    }
    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function affectedKeys() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }
    function groupDoc(gid) {
      return get(/databases/$(database)/documents/groups/$(gid)).data;
    }
    function isGroupAdmin(gid) {
      return isSignedIn() && request.auth.uid in groupDoc(gid).adminIds;
    }
    function isGroupMember(gid) {
      return isSignedIn() && (
        request.auth.uid in groupDoc(gid).playerIds ||
        request.auth.uid in groupDoc(gid).adminIds
      );
    }

    // ── /users/{uid} ────────────────────────────────────────────────────
    // Self can update most fields on their own doc, EXCEPT invite-
    // attribution fields: those are first-set-only and the new value
    // for `invitedBy` must point at someone OTHER than the writer
    // (no self-attribution). Once `invitedBy` is set it can never be
    // overwritten or cleared from the client. Other signed-in users
    // may touch ONLY the `discipline` and `achievements` subfields
    // (+ updatedAt) — used for cross-user counter bumps.
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create: if isSelf(uid) && (
        // Brand-new user — no inviter known yet, OR the inviter is
        // already someone else (the URL/install-referrer attribution
        // path on first signup).
        !('invitedBy' in request.resource.data) ||
        request.resource.data.invitedBy != uid
      );
      allow update: if (
        isSelf(uid) &&
        // Block clobbering attribution: if `invitedBy` already exists
        // it must remain unchanged on every subsequent self-update.
        (
          !('invitedBy' in resource.data) ||
          (
            'invitedBy' in request.resource.data &&
            request.resource.data.invitedBy == resource.data.invitedBy
          )
        ) &&
        // First-time attribution write: must be a foreign uid (no
        // self-invite) and must arrive together with type+target.
        (
          'invitedBy' in resource.data ||
          !('invitedBy' in request.resource.data) ||
          (
            request.resource.data.invitedBy != uid &&
            'invitedByType' in request.resource.data &&
            'invitedByTargetId' in request.resource.data
          )
        )
      ) || (
        isSignedIn() &&
        affectedKeys().hasOnly(['discipline', 'achievements', 'updatedAt'])
      );
      allow delete: if false;
    }

    // ── /groups/{gid} — private community state ─────────────────────────
    // Reads: members + admins only (outsiders use /groupsPublic).
    // Create: the creator becomes the sole admin and only player.
    // Update: admin may change anything; outsiders may only self-add to
    //   pendingPlayerIds (community join-request path).
    match /groups/{gid} {
      allow read: if isSignedIn() && (
        request.auth.uid in resource.data.playerIds ||
        request.auth.uid in resource.data.adminIds ||
        request.auth.uid in resource.data.pendingPlayerIds
      );
      allow create: if isSignedIn() &&
        request.resource.data.adminIds == [request.auth.uid] &&
        request.resource.data.playerIds.hasOnly([request.auth.uid]) &&
        request.resource.data.pendingPlayerIds.size() == 0;
      allow update: if (
        isGroupAdmin(gid) &&
        // creatorId is immutable — once set, neither the creator nor
        // any other admin can rewrite it. Blocks the demote-creator-
        // then-self-promote escalation we identified in the audit.
        (
          !('creatorId' in resource.data) ||
          (
            'creatorId' in request.resource.data &&
            request.resource.data.creatorId == resource.data.creatorId
          )
        ) &&
        // adminIds may only be changed by the creator. Note we use
        // `request.auth.uid == resource.data.creatorId` as the gate
        // — falling back to adminIds[0] (the legacy heuristic) opened
        // the door to promotion races. Legacy groups without an
        // explicit creatorId field can no longer rotate their admin
        // list from the client; they must be backfilled.
        (
          !affectedKeys().hasAny(['adminIds']) ||
          (
            'creatorId' in resource.data &&
            request.auth.uid == resource.data.creatorId
          )
        ) &&
        // The creator must always remain inside adminIds even when
        // the creator themselves is editing.
        (
          !affectedKeys().hasAny(['adminIds']) ||
          (
            'creatorId' in resource.data &&
            resource.data.creatorId in request.resource.data.adminIds
          )
        )
      ) || (
        // self-add to pendingPlayerIds (community join request — closed group)
        isSignedIn() &&
        !(request.auth.uid in resource.data.playerIds) &&
        !(request.auth.uid in resource.data.adminIds) &&
        affectedKeys().hasOnly(['pendingPlayerIds', 'updatedAt']) &&
        request.resource.data.pendingPlayerIds.size() ==
          resource.data.pendingPlayerIds.size() + 1 &&
        request.auth.uid in request.resource.data.pendingPlayerIds
      ) || (
        // self-add to playerIds (auto-join — open group). The flag
        // resource.data.isOpen == true gates this; otherwise the path
        // above (pendingPlayerIds) is the only legal self-write.
        isSignedIn() &&
        resource.data.isOpen == true &&
        !(request.auth.uid in resource.data.playerIds) &&
        !(request.auth.uid in resource.data.adminIds) &&
        affectedKeys().hasOnly(['playerIds', 'updatedAt']) &&
        request.resource.data.playerIds.size() ==
          resource.data.playerIds.size() + 1 &&
        request.auth.uid in request.resource.data.playerIds
      );
      // Group admins can delete the canonical doc; the public mirror is
      // cleaned up by the same caller via the rule directly below.
      allow delete: if isSignedIn() &&
        request.auth.uid in resource.data.adminIds;
    }

    // ── /groupsPublic/{gid} — public discovery projection ───────────────
    // Create is split from update because the /groups/{gid} doc doesn't
    // exist yet at the moment a creator runs the dual-write batch — so
    // isGroupAdmin(gid) would throw and reject a legitimate first write.
    // The companion /groups/{gid} create rule already enforces that the
    // caller becomes the sole admin/player, so allowing the public
    // mirror to be created by any signed-in user is safe.
    match /groupsPublic/{gid} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && isGroupAdmin(gid);
      // Allow deletion by an admin of the (still-existing) canonical group,
      // OR after the canonical doc has already been deleted (rules-driven
      // race: the client deletes /groups first, /groupsPublic second; by
      // the time the second write commits, isGroupAdmin() can't read the
      // deleted doc, so we fall through to a permissive clause).
      allow delete: if isSignedIn() && (
        isGroupAdmin(gid) ||
        !exists(/databases/$(database)/documents/groups/$(gid))
      );
    }

    // ── /groupJoinRequests/{rid} — admin-side audit trail ──────────────
    match /groupJoinRequests/{rid} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        isGroupAdmin(resource.data.groupId)
      );
      allow create: if isSignedIn() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.status == 'pending';
      allow update: if isGroupAdmin(resource.data.groupId) &&
        request.resource.data.status in ['approved', 'rejected'];
      allow delete: if false;
    }

    // ── /games/{id} ─────────────────────────────────────────────────────
    // Reads: strictly gated by `visibility`:
    //   • visibility == 'public' → any signed-in user (Open Games feed).
    //   • visibility == 'community' OR missing → only approved members
    //     and admins of the parent group. Pending users live in
    //     pendingPlayerIds (NOT playerIds/adminIds) and are correctly
    //     excluded by isGroupMember(). The "missing" fallback is
    //     conservative-by-default: if a doc somehow exists without
    //     visibility set, treat it as community-only rather than risk
    //     a silent leak.
    //   isGroupMember() runs a single `get(/groups/{gid})` per rules
    //   evaluation; Firestore caches that read so feed-style queries
    //   pay the lookup once per distinct group.
    // Create: the creator is the organizer (createdBy=self).
    // Update: organizer or group admin can mutate freely; any signed-in
    //   user can self-join (delta-only on participation arrays); any
    //   participant can flag themselves as late on liveMatch.
    //   Lifecycle gate: a `finished` game is read-only from the client.
    //   Visibility flips have an extra constraint inside the
    //   organizer branch: status must be 'open' AND the new value
    //   must be one of the two allowed strings.
    match /games/{id} {
      allow read: if isSignedIn() && (
        resource.data.visibility == 'public' ||
        isGroupMember(resource.data.groupId)
      );

      // Standard create: signed-in user, sets themselves as creator,
      // status starts as 'open'. Visibility validation lives in the
      // converter (defaults missing values to 'community' and
      // rejects bogus enum values), so the rule doesn't re-assert
      // it here — earlier attempts to do so silently denied valid
      // creates and weren't worth the safety margin.
      allow create: if isSignedIn() &&
        request.resource.data.createdBy == request.auth.uid &&
        request.resource.data.status == 'open';

      allow update: if isSignedIn() && (
        // Organizer / admin: can mutate ANYTHING except terminal states
        // (finished/cancelled — historical data, locked from edits).
        // Also blocks joins/cancels via the organizer branch when
        // status='active' so the participation arrays stay frozen
        // mid-evening; the self-join branch below is the only path
        // that touches players/waitlist/pending and it requires
        // status='open'.
        // Note: a previous iteration also asserted a visibility-flip
        // guard here (status==open + valid enum). It was over-eager
        // and silently denied legitimate joins/cancels by community
        // admins. Visibility is now enforced client-side via the
        // dedicated setVisibility() handler + the create rule below.
        (
          (
            request.auth.uid == resource.data.createdBy ||
            isGroupAdmin(resource.data.groupId)
          ) &&
          resource.data.status != 'finished' &&
          resource.data.status != 'cancelled'
        ) ||
        // Self join/cancel — strict delta on the participation arrays:
        //   • status must be 'open' BEFORE and AFTER the write
        //     (Stage 2: 'locked'/'active'/'finished'/'cancelled' all
        //     block this branch).
        //   • startsAt must still be in the future (no late joins).
        //   • liveMatch.phase != 'live' / 'roundRunning' (no joins
        //     once a round is in motion).
        //   • the size of `players` may change by at most 1.
        //   • if `players` size grew, request.auth.uid must be the
        //     newly-added member; if it shrank, the auth user must
        //     be the one removed (i.e. you can only join/cancel
        //     yourself, never push or pull other users).
        (
          resource.data.status == 'open' &&
          request.resource.data.status == 'open' &&
          (
            !('startsAt' in resource.data) ||
            request.time.toMillis() < resource.data.startsAt
          ) &&
          (
            !('liveMatch' in resource.data) ||
            !('phase' in resource.data.liveMatch) ||
            (
              resource.data.liveMatch.phase != 'live' &&
              resource.data.liveMatch.phase != 'roundRunning'
            )
          ) &&
          affectedKeys().hasOnly([
            'players', 'waitlist', 'pending', 'participantIds', 'updatedAt'
          ]) &&
          // Delta size check across all three arrays.
          (
            request.resource.data.players.size() ==
              resource.data.players.size() + 1
              ? request.auth.uid in request.resource.data.players &&
                !(request.auth.uid in resource.data.players)
              : true
          ) &&
          (
            request.resource.data.players.size() ==
              resource.data.players.size() - 1
              ? !(request.auth.uid in request.resource.data.players) &&
                request.auth.uid in resource.data.players
              : true
          ) &&
          (
            // No other size delta is allowed — must be exactly +/- 1
            // OR unchanged (a pure waitlist→pending swap, etc.).
            request.resource.data.players.size() >=
              resource.data.players.size() - 1 &&
            request.resource.data.players.size() <=
              resource.data.players.size() + 1
          )
        ) ||
        // Live-match self-late toggle — any participant may push
        // their OWN uid into liveMatch.lateUserIds. Other liveMatch
        // mutations (assignments / scores / phase) are admin-only
        // and flow through the organizer/admin branch above.
        (
          request.auth.uid in resource.data.participantIds &&
          affectedKeys().hasOnly(['liveMatch', 'updatedAt']) &&
          // Only the lateUserIds sub-array may change.
          request.resource.data.liveMatch.diff(resource.data.liveMatch)
            .affectedKeys().hasOnly(['lateUserIds']) &&
          // The change must include the auth user (they're toggling
          // their own late flag). We allow add or remove of self.
          (
            request.auth.uid in request.resource.data.liveMatch.lateUserIds ||
            request.auth.uid in resource.data.liveMatch.lateUserIds
          )
        )
      );

      allow delete: if isSignedIn() &&
        (request.auth.uid == resource.data.createdBy ||
         isGroupAdmin(resource.data.groupId));
    }

    // ── /rounds/{id} ────────────────────────────────────────────────────
    // Read: signed-in (mirrors /games). Write: game organizer / admin.
    match /rounds/{id} {
      function gameOrgId(gid) {
        return get(/databases/$(database)/documents/games/$(gid)).data.createdBy;
      }
      function gameGroupId(gid) {
        return get(/databases/$(database)/documents/games/$(gid)).data.groupId;
      }

      allow read: if isSignedIn();
      allow create: if isSignedIn() && (
        request.auth.uid == gameOrgId(request.resource.data.gameId) ||
        isGroupAdmin(gameGroupId(request.resource.data.gameId))
      );
      allow update: if isSignedIn() && (
        request.auth.uid == gameOrgId(resource.data.gameId) ||
        isGroupAdmin(gameGroupId(resource.data.gameId))
      );
      allow delete: if false;
    }

    // ── /playerStats/{uid} ──────────────────────────────────────────────
    // Read: any signed-in. Write: server-side only (Cloud Function +
    // Admin SDK bypass these rules).
    match /playerStats/{uid} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // ── /groups/{gid}/ratings — community-scoped player ratings ────────
    // Summary docs (one per rated user) are written ONLY by the
    // onVoteWritten Cloud Function — clients never write them, so a
    // malicious client can't fabricate an inflated average. Reading
    // is open to any signed-in user (the badge on PlayerCard /
    // MemberRow needs it; voter identity stays private via the
    // votes subcollection rule below).
    match /groups/{gid}/ratings/{ratedUid} {
      allow read: if isSignedIn();
      // Trusted writes only — Cloud Function uses admin SDK and
      // bypasses these rules entirely. Client writes are denied.
      allow write: if false;

      // Individual votes: only the rater may write their own vote, and
      // ONLY if both rater and rated are members of the same community.
      // ratedUid must not equal raterUid (no self-rating). Rating must
      // be an integer 1..5. Reading a vote is restricted to the rater
      // themselves so voter identity never leaks.
      match /votes/{raterUid} {
        allow read: if isSignedIn() && request.auth.uid == raterUid;
        allow create, update: if isSignedIn()
          && request.auth.uid == raterUid
          && raterUid != ratedUid
          && isGroupMember(gid)
          && (
            ratedUid in groupDoc(gid).playerIds ||
            ratedUid in groupDoc(gid).adminIds
          )
          && request.resource.data.raterUserId == raterUid
          && request.resource.data.ratedUserId == ratedUid
          && request.resource.data.rating is int
          && request.resource.data.rating >= 1
          && request.resource.data.rating <= 5;
        allow delete: if isSignedIn() && request.auth.uid == raterUid;
      }
    }

    // ── /notifications/{id} (Phase E) ───────────────────────────────────
    // Outbound queue from clients to a Cloud Function consumer. Any
    // signed-in user can create a dispatch — the CF reads the recipient's
    // prefs + tokens before delivering, and it's the CF (not the client)
    // that talks to FCM.
    //
    // Reads: only the recipient or the dispatch's creator can read back
    // a notification doc, since the payload may include light personal
    // info (group name, requester id). Updates / deletes: server-only
    // (Admin SDK bypass).
    match /notifications/{id} {
      allow create: if isSignedIn() &&
        request.resource.data.recipientId is string &&
        request.resource.data.type is string &&
        request.resource.data.delivered == false;
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.recipientId
      );
      allow update, delete: if false;
    }

    // ── /appConfig/{platform} — public version-gate config ─────────────
    // Read by every client on launch (force/optional update prompts).
    // No auth required because the only field is the version threshold,
    // and a stale read just delays the prompt by one launch. Writes are
    // admin-only via the Firebase console / Admin SDK.
    match /appConfig/{platform} {
      allow read: if true;
      allow write: if false;
    }
  }
}
