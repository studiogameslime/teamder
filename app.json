{
  "expo": {
    "name": "Teamder",
    "slug": "soccer-game",
    "version": "0.2.2",
    "orientation": "portrait",
    "icon": "./Logo.png",
    "scheme": [
      "footy",
      "teamder",
      "com.studiogameslime.soccerapp"
    ],
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./Logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#16A34A"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.studiogameslime.soccerapp"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./Logo.png",
        "backgroundColor": "#16A34A"
      },
      "package": "com.studiogameslime.soccerapp",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.POST_NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-localization",
      "@react-native-firebase/app",
      "@react-native-google-signin/google-signin",
      [
        "expo-notifications",
        {
          "icon": "./Logo.png",
          "color": "#16A34A"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "כדי להציג קבוצות כדורגל בקרבת מקום ולעזור לסנן לפי 'קרוב אליי'."
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4452511612073107~1968239705",
          "iosAppId": "ca-app-pub-3940256099942544~1458002511",
          "userTrackingUsageDescription": "This identifier will be used to deliver personalized ads to you.",
          "skAdNetworkItems": []
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "34.0.0"
          },
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "eas": {
        "projectId": "382fd359-9632-4210-ad26-fb967a8a893a"
      }
    },
    "owner": "studiogameslimes-organization"
  }
}
